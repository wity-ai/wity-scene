  "region": "ap-south-1",
  "runtime": "nodejs20.x",
  "handler": "handler.handler",
  "architecture": "x86_64",
  "memorySize": 3008,
  "timeout": 300,
  "ephemeralStorage": 4096,
  "layers": [
    "arn:aws:lambda:ap-south-1:175033217214:layer:ffmpeg:1"

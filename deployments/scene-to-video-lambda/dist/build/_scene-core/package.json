{
  "name": "@wity/scene-core",
  "version": "1.0.0",
  "description": "Headless XML scene-graph library. Parse, evaluate, serialize, and validate wity-scene documents. Zero DOM dependencies.",
  "type": "module",
  "main":   "./dist/scene-core.esm.js",
  "module": "./dist/scene-core.esm.js",
  "exports": {
    ".": {
      "import":  "./dist/scene-core.esm.js",
      "default": "./dist/scene-core.esm.js"
    }
  },
  "files": ["dist", "index.js", "parser", "evaluator", "serializer", "validator", "schema", "utils"],
  "scripts": {
    "build": "rollup -c"
  },
  "keywords": ["scene-graph", "xml", "animation", "compositing", "headless"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
